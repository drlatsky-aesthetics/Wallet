{
  "version": 2,
  "installCommand": "npm install --omit=dev",
  "functions": {
    "api/generate-pass.js":  { "maxDuration": 10 },
    "api/sync-passes.js":    { "maxDuration": 60 },
    "api/list-clients.js":   { "maxDuration": 30 },
    "api/send-pass.js":      { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/generate-pass",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
