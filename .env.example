# ─── Treasury Aesthetics · Apple Wallet Pass · Environment Variables ──────────
# Copy this file to .env.local for local development.
# In production, set these in: Vercel Dashboard → Project → Settings → Environment Variables
# NEVER commit .env.local or any actual certificate values to git.

# ── Apple Developer Credentials ───────────────────────────────────────────────

# Your 10-character Apple Developer Team ID
# Found at: developer.apple.com/account → Membership details
APPLE_TEAM_ID=XXXXXXXXXX

# Pass Type Identifier — must be registered in Apple Developer portal first
# Convention: pass.{reverse-domain}.{descriptor}
# e.g.  pass.ca.treasuryhealth.loyalty
APPLE_PASS_TYPE_ID=pass.ca.treasuryhealth.loyalty

# ── Certificate PEM files (base64-encoded) ────────────────────────────────────
# Encode each PEM file to base64 before pasting here:
#   macOS/Linux:  base64 -i your-file.pem | tr -d '\n'
#   Windows:      certutil -encodehex your-file.pem output.b64 0x40000001

# Apple WWDR G4 Intermediate Certificate (public — download from Apple)
# Source: https://www.apple.com/certificateauthority/ → AppleWWDRCAG4.cer
# Convert: openssl x509 -inform DER -in AppleWWDRCAG4.cer -out wwdr.pem
# Encode:  base64 -i wwdr.pem | tr -d '\n'
APPLE_WWDR_CERT=<base64-encoded-wwdr-pem>

# Your Pass signing certificate (from Apple Developer portal)
# Steps:
#   1. developer.apple.com → Certificates, IDs & Profiles → Create Certificate
#   2. Choose "Pass Type ID Certificate"
#   3. Download the .cer file
#   4. Double-click to add to Keychain
#   5. Export from Keychain as .p12 (set a passphrase)
#   6. openssl pkcs12 -in cert.p12 -clcerts -nokeys -out signer.pem -legacy
#   7. base64 -i signer.pem | tr -d '\n'
APPLE_SIGNER_CERT=<base64-encoded-signer-pem>

# Private key extracted from the same .p12 file
#   openssl pkcs12 -in cert.p12 -nocerts -nodes -out key.pem -legacy
#   base64 -i key.pem | tr -d '\n'
APPLE_SIGNER_KEY=<base64-encoded-key-pem>

# Passphrase you set when exporting the .p12 from Keychain (if any)
# Leave blank if you exported without a passphrase
APPLE_SIGNER_KEY_PASSPHRASE=

# ── Pass Configuration ─────────────────────────────────────────────────────────

# URL encoded in the QR code — swap for patient sign-in portal when ready
PASS_TARGET_URL=https://treasuryhealth.ca

# Allowed origin for CORS (set to your WordPress domain)
ALLOWED_ORIGIN=https://treasuryhealth.ca

# ── Local Development ─────────────────────────────────────────────────────────
NODE_ENV=development
